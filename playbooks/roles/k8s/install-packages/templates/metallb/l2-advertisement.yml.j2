apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: {{ pool_name }}
  namespace: metallb
spec:
  ipAddressPools:
  - {{ pool_name }}
  nodeSelectors:
{% for host_name in host_names %}
  - matchLabels:
      kubernetes.io/hostname: {{ host_name }}
{% endfor %}
  interfaces:
{% for interface in interfaces %}
  - {{ interface }}
{% endfor %}
