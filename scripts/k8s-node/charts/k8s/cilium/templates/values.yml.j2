k8sServiceHost: {{ internal_network_ki_cp_dns_name }}
k8sServicePort: {{ ki_cp_k8s_cp_lb_port }}
image:
  repository: {{ internal_network_ki_cp_dns_name }}:{{ ki_cp_k8s_registry_port }}/cilium/cilium
  useDigest: false
l2announcements:
  enabled: true
bpf:
  masquerade: true
  preallocateMaps: true
ingressController:
  enabled: true
  default: true
  loadbalancerMode: shared
  ingressLBAnnotationPrefixes:
    - lbipam.cilium.io
    - nodeipam.cilium.io
    - service.beta.kubernetes.io
    - service.kubernetes.io
    - cloud.google.com
    - k8s-installer.ten1010.io
{%- if k8s_default_ingress_class_load_balancer %}
  service:
    labels:
      k8s-installer.ten1010.io/load-balancer: {{ k8s_default_ingress_class_load_balancer }}
    annotations:
      lbipam.cilium.io/sharing-key: {{ k8s_default_ingress_class_load_balancer }}
      lbipam.cilium.io/sharing-cross-namespace: "*"
{%- else %}
  hostNetwork:
    enabled: true
    sharedListenerPort: {{ k8s_default_ingress_class_host_network_port }}
{%- endif %}
hubble:
  metrics:
    enabled:
      - dns:query;ignoreAAAA
      - drop
      - tcp
      - flow
      - icmp
      - http
    dashboards:
      enabled: true
  relay:
    enabled: true
    image:
      repository: {{ internal_network_ki_cp_dns_name }}:{{ ki_cp_k8s_registry_port }}/cilium/hubble-relay
      useDigest: false
    prometheus:
      enabled: true
  ui:
    enabled: true
    backend:
      image:
        repository: {{ internal_network_ki_cp_dns_name }}:{{ ki_cp_k8s_registry_port }}/cilium/hubble-ui-backend
        useDigest: false
    frontend:
      image:
        repository: {{ internal_network_ki_cp_dns_name }}:{{ ki_cp_k8s_registry_port }}/cilium/hubble-ui
        useDigest: false
ipam:
  mode: cluster-pool
  operator:
    clusterPoolIPv4PodCIDRList:
    - {{ k8s_pod_subnet }}
kubeProxyReplacement: true
prometheus:
  enabled: true
dashboards:
  enabled: true
envoy:
  image:
    repository: {{ internal_network_ki_cp_dns_name }}:{{ ki_cp_k8s_registry_port }}/cilium/cilium-envoy
    useDigest: false
  securityContext:
    capabilities:
      keepCapNetBindService: true
      envoy:
        - NET_ADMIN
        - SYS_ADMIN
        - NET_BIND_SERVICE
operator:
  image:
    repository: {{ internal_network_ki_cp_dns_name }}:{{ ki_cp_k8s_registry_port }}/cilium/operator
    useDigest: false
  dashboards:
    enabled: true
